            " Best Parameter: {'n_estimators': 300, 'min_samples_split': 10, 'min_samples_leaf': 8, 'max_depth': 15}\n",
            "Best CV: 0.870\n"
          ]
        }
      ],
      "source": [
        "# tuning the model using random search cv to get the best parameters\n",
        "param_distributions = {\n",
        "    'n_estimators':[200,300,400],\n",
        "    'max_depth':[15,20,25],\n",
        "    'min_samples_split':[5,10,15],\n",
