      "source": [
        "# What is the rate of placement?\n",
        "placement = df[df['placement_status'] == 'Placed']\n",
        "num_placement = len(placement)\n",
        "total_number = len(df)\n",
        "rate_placement = (num_placement / total_number) * 100\n",
        "print(f'The rate of placement is {round(rate_placement)}%')"
      ]
    },
